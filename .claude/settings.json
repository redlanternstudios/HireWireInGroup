    "deny": [
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf:*)",
      "Bash(supabase db reset:*)",
      "Bash(supabase db push:*)"
    ]
  }
}

