{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(for *:*)",
      "Bash(if *:*)",
      "Bash(echo *:*)",
      "Bash(cat *:*)",
      "Bash(ls *:*)",
      "Bash(find *:*)",
      "Bash(npm run *:*)",
      "Bash(npx *:*)",
      "Bash(node *:*)",
      "Bash(mkdir *:*)",
      "Bash(cp *:*)",
      "Bash(mv *:*)",
      "Bash(touch *:*)"
    ],
    "deny": [
      "Bash(rm -rf /*:*)",
      "Bash(sudo *:*)",
      "Bash(chmod 777:*)"
    ]
  }
}
