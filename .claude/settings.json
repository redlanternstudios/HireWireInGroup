{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[CLAUDE EDIT] '$(date +%H:%M)' '$CLAUDE_TOOL_INPUT_FILE_PATH >> .claude/task_log.txt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -15"
          }
        ]
      }
    ]
  }
}
